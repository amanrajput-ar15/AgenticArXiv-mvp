# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AgenticArXiv .gitignore


# Environment Variables (CRITICAL)

# Never commit your Gemini, Langfuse, or MongoDB URIs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# (It is okay to commit .env.example)


# Local Data & Vector Stores

# Ignore all downloaded PDFs, extracted images, and FAISS vector databases
backend/data/
/mnt/volume/
*.pdf
*.png
*.index
*.pkl
.write_lock
extraction_cache/


# Python Backend

# Virtual Environments
backend/venv/
venv/
env/
.venv/

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# Next.js / React Frontend

frontend/node_modules/
node_modules/
frontend/.next/
.next/
frontend/out/
out/
build/

# Node/npm/yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js specific
.vercel
next-env.d.ts


# OS & IDE Files

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors (VS Code, IntelliJ, etc.)
.vscode/
.idea/
*.swp
*.swo